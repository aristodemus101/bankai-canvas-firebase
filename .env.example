# Firebase project config (from Firebase Console → Project Settings → Web App)
VITE_FB_API_KEY=your_firebase_api_key
VITE_FB_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FB_PROJECT_ID=your-project-id
VITE_FB_STORAGE_BUCKET=your-project.appspot.com
VITE_FB_MESSAGING_ID=000000000000
VITE_FB_APP_ID=1:000:web:000

# Cloud Function URL (set after first deploy — see README Step 6)
VITE_SUMMARIZE_URL=https://us-central1-YOUR_PROJECT.cloudfunctions.net/summarize

# Gemini API key (set as Firebase secret — see README Step 5)
# Don't put this here — it goes in Firebase secrets, not .env
